{
    "name": "muazzambuilds/filament-ban",
    "description": "Ban and suspend users from Filament — middleware blocks panel, API, and login.",
    "keywords": [
        "filament",
        "filament-plugin",
        "laravel",
        "ban",
        "suspend",
        "user-ban",
        "access-control"
    ],
    "homepage": "https://github.com/muazzambuilds/filament-ban",
    "license": "MIT",
    "authors": [
        {
            "name": "Muazzam Builds",
            "email": "me@muazzamalikhan.com",
            "homepage": "https://github.com/muazzambuilds"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/auth": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "MuazzamBuilds\\FilamentBan\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MuazzamBuilds\\FilamentBan\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MuazzamBuilds\\FilamentBan\\FilamentBanServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
